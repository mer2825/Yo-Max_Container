# ===================================================================
# BASE DE DATOS - PostgreSQL
# ===================================================================
# NOTA: Railway proporciona DATABASE_URL automáticamente
# Si Railway no lo proporciona, format es:
# postgresql://username:password@hostname:port/database_name

# DATABASE_URL se genera automáticamente en Railway
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
SQL_INIT_MODE=never

